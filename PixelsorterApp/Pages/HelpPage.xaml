<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PixelsorterApp.Pages.HelpPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:indiko="clr-namespace:Indiko.Maui.Controls.Markdown;assembly=Indiko.Maui.Controls.Markdown">
    <Grid
        Padding="15"
        RowDefinitions="Auto,*"
        RowSpacing="14">
        <Label
            Grid.Row="0"
            FontAttributes="Bold"
            FontSize="24"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            SemanticProperties.HeadingLevel="Level1"
            Text="How to use the Pixelsorter" />
        <ScrollView Grid.Row="1">
            <indiko:MarkdownView
                x:Name="MarkdownDisplay"
                TextFontSize="15"
                UseAppTheme="True" />
        </ScrollView>
    </Grid>
</ContentPage>