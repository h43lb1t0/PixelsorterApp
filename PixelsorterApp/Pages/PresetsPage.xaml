<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PixelsorterApp.Pages.PresetsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:viewModels="clr-namespace:PixelsorterApp.ViewModels"
    x:DataType="viewModels:PresetsPageViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight},
                                      Dark={StaticResource PageBackgroundDark}}"
    Title="Presets">
    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,30" Spacing="16">
            <Label
                FontAttributes="Bold"
                FontSize="13"
                SemanticProperties.HeadingLevel="Level2"
                Text="PRESET DETAILS"
                TextColor="{AppThemeBinding Light={StaticResource Primary},
                                            Dark={StaticResource PrimaryDark}}" />

            <Border
                Padding="16"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                  Dark={StaticResource SurfaceDark}}"
                Stroke="{AppThemeBinding Light={StaticResource DividerLight},
                                         Dark={StaticResource DividerDark}}"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="1"
                StyleClass="Elevation3">
                <Border.Shadow>
                    <Shadow
                        Brush="{AppThemeBinding Light={StaticResource Black},
                                                Dark={StaticResource White}}"
                        Opacity="0.10"
                        Radius="10"
                        Offset="0,3" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Create your preset by configuring the options below. The currently shown preset is based on your selections. Use the TOML map to find out how to configure each option." />
                    <Button
                        Command="{Binding ToggleTomlMapVisibilityCommand}"
                        HorizontalOptions="Start"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Text="{Binding TomlMapToggleText}" />
                    <Border
                        IsVisible="{Binding IsTomlMapVisible}"
                        Padding="10"
                        Stroke="{AppThemeBinding Light={StaticResource DividerLight},
                                                 Dark={StaticResource DividerDark}}"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1">
                        <Label Text="{Binding TomlMapString}" />
                    </Border>
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="Preset TOML"
                        TextColor="{AppThemeBinding Light={StaticResource Primary},
                                                    Dark={StaticResource PrimaryDark}}" />
                    <Border
                        Padding="10"
                        Stroke="{AppThemeBinding Light={StaticResource Primary},
                                                 Dark={StaticResource PrimaryDark}}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1">
                        <Editor
                            AutoSize="TextChanges"
                            Text="{Binding PresetToml}"
                            VerticalOptions="Start" />
                    </Border>
                    <material:TextField Title="Preset Name" Text="{Binding PresetName}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <material:CheckBox
                            Grid.Column="0"
                            IsChecked="{Binding MakeDefaultPreset}"
                            VerticalOptions="Center" />
                        <Label
                            Grid.Column="1"
                            Text="Set as default preset"
                            VerticalOptions="Center" />
                    </Grid>
                    <Button
                        Command="{Binding SetBaseAsDefaultPresetCommand}"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Text="Set base preset as default" />
                    <Button Command="{Binding SavePresetCommand}" Text="Save Preset" />
                    <Label
                        FontSize="13"
                        Text="{Binding SavePresetValidationMessage}"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <Label
                FontAttributes="Bold"
                FontSize="13"
                SemanticProperties.HeadingLevel="Level2"
                Text="AVAILABLE PRESETS"
                TextColor="{AppThemeBinding Light={StaticResource Primary},
                                            Dark={StaticResource PrimaryDark}}" />

            <Border
                Padding="16"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight},
                                                  Dark={StaticResource SurfaceDark}}"
                Stroke="{AppThemeBinding Light={StaticResource DividerLight},
                                         Dark={StaticResource DividerDark}}"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="1">
                <Border.Shadow>
                    <Shadow
                        Brush="{AppThemeBinding Light={StaticResource Black},
                                                Dark={StaticResource White}}"
                        Opacity="0.10"
                        Radius="10"
                        Offset="0,3" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <Label
                            Grid.Column="0"
                            FontAttributes="Bold"
                            Text="Preset" />
                        <Label
                            Grid.Column="1"
                            Margin="12,0,0,0"
                            FontAttributes="Bold"
                            Text="Edit" />
                        <Label
                            Grid.Column="2"
                            Margin="12,0,0,0"
                            FontAttributes="Bold"
                            Text="Delete" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding AvilablePresets}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:PresetsPageViewModel+PresetListItem">
                                <Grid
                                    Padding="0,6"
                                    ColumnDefinitions="*,Auto,Auto">
                                    <Label
                                        Grid.Column="0"
                                        VerticalOptions="Center"
                                        Text="{Binding Name}" />
                                    <Button
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditPresetCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Text="Edit" />
                                    <Button
                                        Grid.Column="2"
                                        Margin="12,0,0,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeletePresetCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Text="Delete" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>