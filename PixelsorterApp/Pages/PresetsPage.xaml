<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PixelsorterApp.Pages.PresetsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:viewModels="clr-namespace:PixelsorterApp.ViewModels"
    Title="PresetPage">
    <ScrollView>

        

        <VerticalStackLayout>
            <Label Text="Preset Details" FontAttributes="Bold" FontSize="20" Margin="10" />
            <Label Text="Create your preset by configuring the options below. The currently shown preset is based on your selections. Use the tomlMap to find out how to configure each option." />
            <Label Text="{Binding TomlMapString}" />
            <material:EditorField Title="Description" Text="{Binding PresetToml}" />

            <Button Text="Save Preset" Command="{Binding SavePresetCommand}" />
            <Label Text="{Binding SavePresetValidationMessage}" />

            <material:TextField Title="Preset Name" Text="{Binding PresetName}" />
            <Label Text="Set as default preset" />
            <material:CheckBox IsChecked="{Binding MakeDefaultPreset}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>