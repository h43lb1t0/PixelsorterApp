<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PixelsorterApp"
             x:Class="PixelsorterApp.LicensesPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}"
             Title="Open Source Licenses"
             SemanticProperties.Description="Open source licenses used by the app">


    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">
            <Label Text="Open Source Licenses" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" SemanticProperties.HeadingLevel="Level1" />
            <Label Text="This application uses the following open source packages:" Opacity="0.8" />

            <Border
                Stroke="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                Padding="0"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout x:Name="LicensesContainer" Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="local:LicenseInfo">
                            <VerticalStackLayout Padding="16" Spacing="4">
                                <Label Text="{Binding PackageName}" FontSize="16" FontAttributes="Bold" SemanticProperties.HeadingLevel="Level2" />
                                <Label Text="{Binding Authors}" FontSize="13" Opacity="0.8" />
                                <Label Text="{Binding PackageVersion}" FontSize="13" Opacity="0.6" />
                                <Label Text="{Binding LicenseType}" FontSize="13" Opacity="0.8" />
                                <Button
                                    Text="{Binding LicenseUrl}"
                                    Style="{StaticResource LinkButtonStyle}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type local:LicensesPage}}, Path=OpenUrlCommand}"
                                    CommandParameter="{Binding LicenseUrl}"
                                    SemanticProperties.Description="{Binding LicenseUrl, StringFormat='Open license URL: {0}'}"
                                    SemanticProperties.Hint="Press Enter to open this license in the browser" />
                                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" Margin="0,8,0,0" AutomationProperties.IsInAccessibleTree="False" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Border>
            <Label Text="Additional Licenses" FontSize="20" FontAttributes="Bold" Margin="0,16,0,8" SemanticProperties.HeadingLevel="Level2" />
            <Border
                Stroke="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                Padding="0"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Padding="16" Spacing="4">
                    <Label Text="RMBG-1.4" FontSize="16" FontAttributes="Bold" SemanticProperties.HeadingLevel="Level3" />
                    <Label Text="Bria.ai" FontSize="13" Opacity="0.8" />
                    <Label Text="CC-BY-NC" FontSize="13" Opacity="0.8" />
                    <Button
                        Text="https://creativecommons.org/licenses/by-nc/4.0/"
                        Style="{StaticResource LinkButtonStyle}"
                        Command="{Binding Source={RelativeSource AncestorType={x:Type local:LicensesPage}}, Path=OpenUrlCommand}"
                        CommandParameter="https://creativecommons.org/licenses/by-nc/4.0/"
                        SemanticProperties.Description="Open license URL: https://creativecommons.org/licenses/by-nc/4.0/"
                        SemanticProperties.Hint="Press Enter to open this license in the browser" />
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" Margin="0,8,0,0" AutomationProperties.IsInAccessibleTree="False" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
