<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PixelsorterApp.MainPage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#FFF7ED, Dark=#1C1917}">

    <ContentPage.MenuBarItems>
        <MenuBarItem Text="Help">
            <MenuFlyoutItem Text="Open Source Licenses"
                            Clicked="LicensesBtn_Clicked" />
        </MenuBarItem>
    </ContentPage.MenuBarItems>

    <ContentPage.Resources>
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#7C2D12, Dark=#FED7AA}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="HeightRequest" Value="48" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#EA580C, Dark=#C2410C}" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup Name="CommonStates">
                        <VisualState Name="Normal" />
                        <VisualState Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#FDBA74, Dark=#7C2D12}" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#FFF7ED, Dark=#FED7AA}" />
                                <Setter Property="Opacity" Value="0.7" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout
            Padding="20,20,20,30"
            Spacing="16">

            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8">
                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    Text="Pixel Sorter"
                    FontSize="28"
                    FontAttributes="Bold" />
                <Label
                    Grid.Row="1"
                    Grid.Column="0"
                    Text="Load an image, choose options, and sort."
                    FontSize="14"
                    Opacity="0.8" />
                <Button
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="1"
                    Text="⋮"
                    Clicked="LicensesBtn_Clicked"
                    WidthRequest="36"
                    HeightRequest="36"
                    Padding="0"
                    CornerRadius="18"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#9A3412, Dark=#FED7AA}"
                    FontSize="22"
                    SemanticProperties.Description="Open additional app options" />
            </Grid>

            <Border
                Stroke="{AppThemeBinding Light=#FDBA74, Dark=#9A3412}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#FFFDF9, Dark=#292524}"
                Padding="12"
                StrokeShape="RoundRectangle 16">
                <Grid>
                    <Image
                        x:Name="LoadImageBtn"
                        Source="uploadplaceholder.png"
                        Aspect="AspectFit"
                        MaximumHeightRequest="300"
                        HeightRequest="130">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="LoadImage_Clicked" />
                        </Image.GestureRecognizers>
                    </Image>

                    <Grid
                        x:Name="sortingOverlay"
                        IsVisible="False"
                        BackgroundColor="#80000000"
                        InputTransparent="False">
                        <VerticalStackLayout
                            Spacing="10"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                            <ActivityIndicator
                                x:Name="sortingIndicator"
                                IsRunning="False"
                                Color="White"
                                WidthRequest="40"
                                HeightRequest="40" />
                            <Label
                                Text="Sorting..."
                                TextColor="White"
                                FontAttributes="Bold"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Grid>
            </Border>
            
            <Label Text="OPTIONS" FontSize="13" TextColor="{AppThemeBinding Light=#EA580C, Dark=#C2410C}" FontAttributes="Bold" Margin="4,10,4,4" />

            <Border
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#FFEDD5, Dark=#292524}"
                Padding="0"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="56" Padding="16,0">
                        <Label
                            Text="Sort by"
                            FontSize="16"
                            VerticalOptions="Center" />
                        <material:PickerField
                            x:Name="sortBy"
                            Grid.Column="1"
                            AllowClear="False"
                            BorderColor="Transparent"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#9A3412, Dark=#FED7AA}"
                            AccentColor="{AppThemeBinding Light=#EA580C, Dark=#C2410C}"
                            VerticalOptions="Center"
                            HorizontalOptions="End"
                            SemanticProperties.Description="A dropdown menu to select what to sort the Pixels by" />
                        <Label
                            Grid.Column="2"
                            Text="⌄"
                            FontSize="18"
                            TextColor="{AppThemeBinding Light=#9A3412, Dark=#FED7AA}"
                            VerticalOptions="Center"
                            InputTransparent="True"
                            Opacity="0.7"
                            Margin="4,0,0,0" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#FDBA74, Dark=#9A3412}" Opacity="0.15" Margin="16,0,0,0" />

                    <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="56" Padding="16,0">
                        <Label
                            Text="Direction"
                            FontSize="16"
                            VerticalOptions="Center" />
                        <material:PickerField
                            x:Name="sortDirection"
                            Grid.Column="1"
                            AllowClear="False"
                            BorderColor="Transparent"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#9A3412, Dark=#FED7AA}"
                            AccentColor="{AppThemeBinding Light=#EA580C, Dark=#C2410C}"
                            VerticalOptions="Center"
                            HorizontalOptions="End"
                            SemanticProperties.Description="A dropdown to select in what direction to sort the pixels" />
                        <Label
                            Grid.Column="2"
                            Text="⌄"
                            FontSize="18"
                            TextColor="{AppThemeBinding Light=#9A3412, Dark=#FED7AA}"
                            VerticalOptions="Center"
                            InputTransparent="True"
                            Opacity="0.7"
                            Margin="4,0,0,0" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#FDBA74, Dark=#9A3412}" Opacity="0.15" Margin="16,0,0,0" />

                    <Grid ColumnDefinitions="*,Auto" HeightRequest="56" Padding="16,0">
                        <Label
                            Text="Use masking"
                            FontSize="16"
                            VerticalOptions="Center" />
                        <Switch
                            x:Name="useMasking"
                            Grid.Column="1"
                            VerticalOptions="Center"
                            OnColor="{AppThemeBinding Light=#FDBA74, Dark=#9A3412}"
                            ThumbColor="{AppThemeBinding Light=#EA580C, Dark=#C2410C}"
                            Toggled="useMasking_Toggled" 
                            SemanticProperties.Description="Toggle switch to turn on or of masking the subject"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#FDBA74, Dark=#9A3412}" Opacity="0.15" Margin="16,0,0,0" IsVisible="{Binding IsVisible, Source={x:Reference maskPadding}}" />

                    <Grid ColumnDefinitions="*,100" HeightRequest="56" Padding="16,0" IsVisible="{Binding IsVisible, Source={x:Reference maskPadding}}">
                        <Label
                            Text="Mask padding (px)"
                            FontSize="16"
                            VerticalOptions="Center" />
                        <material:TextField
                            x:Name="maskPadding"
                            Grid.Column="1"
                            Keyboard="Numeric"
                            AllowClear="False"
                            BorderColor="Transparent"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#9A3412, Dark=#FED7AA}"
                            AccentColor="{AppThemeBinding Light=#EA580C, Dark=#C2410C}"
                            VerticalOptions="Center"
                            HorizontalOptions="Fill"
                            TextChanged="maskPadding_TextChanged"
                            Text="15"
                            IsVisible="False">

                            <material:TextField.Behaviors>
                                <toolkit:NumericValidationBehavior 
                                        Flags="ValidateOnValueChanged"
                                        MinimumValue="1.0"
                                        MaximumValue="100.0"
                                        MaximumDecimalPlaces="0" />
                            </material:TextField.Behaviors>
                        </material:TextField>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button
                x:Name="sortBtn"
                Text="Sort"
                Clicked="sortBtn_Clicked"
                HorizontalOptions="Fill" 
                SemanticProperties.Description="Button to run the pixel sorting"/>

            <Button
                x:Name="saveBtn"
                Text="Save"
                Clicked="SaveBtn_Clicked"
                HorizontalOptions="Fill"
                IsVisible="False"
                SemanticProperties.Description="Button to save the sorted image to the image gallery"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
