<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PixelsorterApp.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                x:Name="imgShower"
                Source="dotnet_bot.png"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />


            <Button
                x:Name="LoadImageBtn"
                Text="Load Image" 
                Clicked="LoadImage_Clicked"
                HorizontalOptions="Fill" />

            <Button
                x:Name="sortBtn"
                Text="Sort"
                Clicked="sortBtn_Clicked"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
