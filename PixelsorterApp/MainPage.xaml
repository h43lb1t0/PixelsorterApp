<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PixelsorterApp.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                x:Name="imgShower"
                Source="dotnet_bot.png"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />


            <Button
                x:Name="LoadImageBtn"
                Text="Load Image" 
                Clicked="LoadImage_Clicked"
                HorizontalOptions="Fill" />

            <HorizontalStackLayout
                Spacing="10"
                HorizontalOptions="Fill">

                <Button
                    x:Name="sortBtn"
                    Text="Sort"
                    Clicked="sortBtn_Clicked"
                    HorizontalOptions="Fill" />

                <VerticalStackLayout>

                    <Label 
                        Text="Use masking" />

                    <Switch
                        x:Name="useMasking"
                        Toggled="useMasking_Toggled" />

                </VerticalStackLayout>


            </HorizontalStackLayout>

            <Label Text="Options" />

            <Picker
                x:Name="sortBy"
                Title="Select what to sort the pixels by" 
                SelectedIndexChanged="sortBy_SelectedIndexChanged" />

            <Picker
                x:Name="sortDirection"
                Title="Select the direction to sort the pixels in" 
                SelectedIndexChanged="sortDirection_SelectedIndexChanged" />

            <Button
                x:Name="saveBtn"
                Text="Save"
                Clicked="SaveBtn_Clicked"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
