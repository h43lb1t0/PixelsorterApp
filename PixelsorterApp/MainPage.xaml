<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PixelsorterApp.MainPage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:localization="clr-namespace:PixelsorterApp.Localization"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}">

    <ContentPage.MenuBarItems>
        <MenuBarItem Text="{localization:Translate HelpMenu}">
            <MenuFlyoutItem Text="{localization:Translate OpenSourceLicensesMenuItem}"
                            Clicked="LicensesBtn_Clicked" />
        </MenuBarItem>
    </ContentPage.MenuBarItems>

    <ContentPage.Resources>
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#212121, Dark=#F5F5F5}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="HeightRequest" Value="48" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#D32F2F, Dark=#E53935}" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#FFFFFF, Dark=#FFFFFF}" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup Name="CommonStates">
                        <VisualState Name="Normal" />
                        <VisualState Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#EF9A9A, Dark=#B71C1C}" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#FFEBEE, Dark=#FFCDD2}" />
                                <Setter Property="Opacity" Value="0.7" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout
            Padding="20,20,20,30"
            Spacing="16">

            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8">
                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    Text="{localization:Translate AppTitle}"
                    FontSize="28"
                    FontAttributes="Bold" />
                <Label
                    Grid.Row="1"
                    Grid.Column="0"
                    Text="{localization:Translate AppSubtitle}"
                    FontSize="14"
                    Opacity="0.8" />
                <Button
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="1"
                    Text="⋮"
                    Clicked="LicensesBtn_Clicked"
                    WidthRequest="36"
                    HeightRequest="36"
                    Padding="0"
                    CornerRadius="18"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#757575, Dark=#9E9E9E}"
                    FontSize="22"
                    SemanticProperties.Description="{localization:Translate MoreOptionsSemantic}" />
            </Grid>

            <Border
                x:Name="imagePreviewBorder"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#303030}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                Padding="12"
                StrokeShape="RoundRectangle 16">
                <Grid>
                    <Image
                        x:Name="LoadImageBtn"
                        Source="uploadplaceholder.png"
                        Aspect="AspectFit"
                        HeightRequest="130">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="LoadImage_Clicked" />
                        </Image.GestureRecognizers>
                    </Image>

                    <Grid
                        x:Name="loadingOverlay"
                        IsVisible="False"
                        BackgroundColor="#80000000"
                        InputTransparent="False">
                        <VerticalStackLayout
                            Spacing="10"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                            <ActivityIndicator
                                x:Name="loadingIndicator"
                                IsRunning="False"
                                Color="White"
                                WidthRequest="40"
                                HeightRequest="40" />
                            <Label
                                x:Name="loadingOverlayLabel"
                                Text=""
                                TextColor="White"
                                FontAttributes="Bold"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Grid>
            </Border>

            <Label Text="{localization:Translate OptionsHeader}" FontSize="13" TextColor="{AppThemeBinding Light=#D32F2F, Dark=#E53935}" FontAttributes="Bold" Margin="4,10,4,4" />

            <Border
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                Padding="0"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="56" Padding="16,0">
                        <Label
                            Text="{localization:Translate SortByLabel}"
                            FontSize="16"
                            VerticalOptions="Center" />
                        <material:PickerField
                            x:Name="sortBy"
                            Grid.Column="1"
                            AllowClear="False"
                            BorderColor="Transparent"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#212121, Dark=#F5F5F5}"
                            AccentColor="{AppThemeBinding Light=#D32F2F, Dark=#E53935}"
                            VerticalOptions="Center"
                            HorizontalOptions="End"
                            SemanticProperties.Description="{localization:Translate SortBySemantic}" />
                        <Label
                            Grid.Column="2"
                            Text="⌄"
                            FontSize="18"
                            TextColor="{AppThemeBinding Light=#757575, Dark=#9E9E9E}"
                            VerticalOptions="Center"
                            InputTransparent="True"
                            Opacity="0.7"
                            Margin="4,0,0,0" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#303030}" Margin="16,0,0,0" />

                    <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="56" Padding="16,0">
                        <Label
                            Text="{localization:Translate DirectionLabel}"
                            FontSize="16"
                            VerticalOptions="Center" />
                        <material:PickerField
                            x:Name="sortDirection"
                            Grid.Column="1"
                            AllowClear="False"
                            BorderColor="Transparent"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#212121, Dark=#F5F5F5}"
                            AccentColor="{AppThemeBinding Light=#D32F2F, Dark=#E53935}"
                            VerticalOptions="Center"
                            HorizontalOptions="End"
                            SemanticProperties.Description="{localization:Translate DirectionSemantic}" />
                        <Label
                            Grid.Column="2"
                            Text="⌄"
                            FontSize="18"
                            TextColor="{AppThemeBinding Light=#757575, Dark=#9E9E9E}"
                            VerticalOptions="Center"
                            InputTransparent="True"
                            Opacity="0.7"
                            Margin="4,0,0,0" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#303030}" Margin="16,0,0,0" />

                    <Grid ColumnDefinitions="*,Auto" HeightRequest="56" Padding="16,0">
                        <Label
                            Text="{localization:Translate UseMaskingLabel}"
                            FontSize="16"
                            VerticalOptions="Center" />
                        <Switch
                            x:Name="useMasking"
                            Grid.Column="1"
                            VerticalOptions="Center"
                            OnColor="{AppThemeBinding Light=#EF9A9A, Dark=#B71C1C}"
                            ThumbColor="{AppThemeBinding Light=#D32F2F, Dark=#E53935}"
                            Toggled="useMasking_Toggled" 
                            SemanticProperties.Description="{localization:Translate UseMaskingSemantic}"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#303030}" Margin="16,0,0,0" IsVisible="{Binding IsVisible, Source={x:Reference maskPadding}}" />

                    <Grid ColumnDefinitions="*,100" HeightRequest="56" Padding="16,0" IsVisible="{Binding IsVisible, Source={x:Reference maskPadding}}">
                        <Label
                            Text="{localization:Translate MaskPaddingLabel}"
                            FontSize="16"
                            VerticalOptions="Center" />
                        <material:TextField
                            x:Name="maskPadding"
                            Grid.Column="1"
                            Keyboard="Numeric"
                            AllowClear="False"
                            BorderColor="Transparent"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#212121, Dark=#F5F5F5}"
                            AccentColor="{AppThemeBinding Light=#D32F2F, Dark=#E53935}"
                            VerticalOptions="Center"
                            HorizontalOptions="Fill"
                            TextChanged="maskPadding_TextChanged"
                            Text="15"
                            IsVisible="False">

                            <material:TextField.Behaviors>
                                <toolkit:NumericValidationBehavior 
                                        Flags="ValidateOnValueChanged"
                                        MinimumValue="1.0"
                                        MaximumValue="100.0"
                                        MaximumDecimalPlaces="0" />
                            </material:TextField.Behaviors>
                        </material:TextField>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#303030}" Margin="16,0,0,0" IsVisible="{Binding IsVisible, Source={x:Reference maskPadding}}" />

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Padding="16,10" IsVisible="{Binding IsVisible, Source={x:Reference maskPadding}}">
                        <Label
                            Grid.Row="0"
                            Text="{localization:Translate WhatToSortLabel}"
                            FontSize="16"
                            VerticalOptions="Center" />
                        <HorizontalStackLayout Grid.Column="1" Spacing="16" HorizontalOptions="End" VerticalOptions="Center">
                            <RadioButton
                                x:Name="sortBackgroundRadio"
                                Content="{localization:Translate BackgroundOption}"
                                IsChecked="True"
                                CheckedChanged="whatToSort_CheckedChanged"
                                SemanticProperties.Description="{localization:Translate BackgroundSemantic}" />
                            <RadioButton
                                x:Name="sortForegroundRadio"
                                Content="{localization:Translate ForegroundOption}"
                                CheckedChanged="whatToSort_CheckedChanged"
                                SemanticProperties.Description="{localization:Translate ForegroundSemantic}" />
                        </HorizontalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button
                x:Name="sortBtn"
                Text="{localization:Translate SortButton}"
                Clicked="sortBtn_Clicked"
                HorizontalOptions="Fill" 
                SemanticProperties.Description="{localization:Translate SortButtonSemantic}"/>

            <Button
                x:Name="saveBtn"
                Text="{localization:Translate SaveButton}"
                Clicked="SaveBtn_Clicked"
                HorizontalOptions="Fill"
                IsVisible="False"
                SemanticProperties.Description="{localization:Translate SaveButtonSemantic}"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
