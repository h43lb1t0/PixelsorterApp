<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PixelsorterApp"
             xmlns:localization="clr-namespace:PixelsorterApp.Localization"
             x:Class="PixelsorterApp.LicensesPage"
             BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}"
             Title="{localization:Translate LicensesPageTitle}">
    <ContentPage.Resources>
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#212121, Dark=#F5F5F5}" />
        </Style>
    </ContentPage.Resources>
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">
            <Label Text="{localization:Translate LicensesPageHeader}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="{localization:Translate LicensesPageIntro}" Opacity="0.8" />

            <Border
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#303030}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                Padding="0"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout x:Name="LicensesContainer" Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="local:LicenseInfo">
                            <VerticalStackLayout Padding="16" Spacing="4">
                                <Label Text="{Binding PackageName}" FontSize="16" FontAttributes="Bold" />
                                <Label Text="{Binding Authors}" FontSize="13" Opacity="0.8" />
                                <Label Text="{Binding PackageVersion}" FontSize="13" Opacity="0.6" />
                                <Label Text="{Binding LicenseType}" FontSize="13" Opacity="0.8" />
                                <Label Text="{Binding LicenseUrl}" FontSize="13" TextColor="{AppThemeBinding Light=#1565C0, Dark=#64B5F6}" TextDecorations="Underline">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type local:LicensesPage}}, Path=OpenUrlCommand}" CommandParameter="{Binding LicenseUrl}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#303030}" Margin="0,8,0,0" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Border>
            <Label Text="{localization:Translate AdditionalLicensesHeader}" FontSize="20" FontAttributes="Bold" Margin="0,16,0,8"  />
            <Border
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#303030}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                Padding="0"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Padding="16" Spacing="4">
                    <Label Text="RMBG-1.4" FontSize="16" FontAttributes="Bold" />
                    <Label Text="Bria.ai" FontSize="13" Opacity="0.8" />
                    <Label Text="CC-BY-NC" FontSize="13" Opacity="0.8" />
                    <Label Text="https://creativecommons.org/licenses/by-nc/4.0/" FontSize="13" TextColor="{AppThemeBinding Light=#1565C0, Dark=#64B5F6}" TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type local:LicensesPage}}, Path=OpenUrlCommand}" CommandParameter="https://creativecommons.org/licenses/by-nc/4.0/" />
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#303030}" Margin="0,8,0,0" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
